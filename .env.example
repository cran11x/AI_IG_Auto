PORT=3000
# Public tunnel for UChat: npm run dev:public
# TUNNEL=serveo (default) → https://*.serveousercontent.com  |  TUNNEL=pinggy → pinggy-free.link
# TUNNEL=serveo

GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: grok-4, grok-3, grok-4-fast-non-reasoning, etc. (see xAI docs)
GROK_MODEL=grok-4

# ── Per-bot timezones (IANA). Used for TIME_CONTEXT in Grok prompt. ────────────
# Esma local time. Default: Europe/London
# ESMA_TIMEZONE=Europe/London
# Sara local time. Default: America/New_York (Miami nije IANA — koristi New_York/EST)
# SARA_TIMEZONE=America/New_York

MANYCHAT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── UChat API keys ────────────────────────────────────────────────────────────
# Globalni fallback (koristi se kad UCHAT_<BOT>_API_KEY nije postavljen).
# U pravilu jedan workspace = jedan API key, pa je ovo dovoljno.
UCHAT_API_KEY=your_uchat_api_key
# Opcionalno, ako za svakog bota želiš zaseban key:
# UCHAT_ESMA_API_KEY=...
# UCHAT_SARA_API_KEY=...

# Message cluster debounce (ms). Default: 30–90 min silence before one Grok reply.
# For local testing use e.g. DEBOUNCE_MIN_MS=3000 DEBOUNCE_MAX_MS=8000
# DEBOUNCE_MIN_MS=1800000
# DEBOUNCE_MAX_MS=5400000

# Optional: require ?token=... on GET /messages when exposing a public tunnel
# VIEW_MESSAGES_TOKEN=your-random-secret
