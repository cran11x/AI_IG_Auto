PORT=3000
# Public tunnel for UChat: npm run dev:public
# TUNNEL=serveo (default) → https://*.serveousercontent.com  |  TUNNEL=pinggy → pinggy-free.link
# TUNNEL=serveo

GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: grok-4, grok-3, grok-4-fast-non-reasoning, etc. (see xAI docs)
GROK_MODEL=grok-4

# ── Per-bot timezones (IANA). Used for TIME_CONTEXT in Grok prompt. ────────────
#Esma local time. Default: Europe/London
ESMA_TIMEZONE=Europe/London
#Sara local time. Default: America/New_York (Miami nije IANA — koristi New_York/EST)
SARA_TIMEZONE=America/New_York

# Sara Exclu unlock link (used in her system prompt; optional if default in sara.js is ok)
# EXCLU_LINK=https://exclu.at/l/...

MANYCHAT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── UChat API keys ────────────────────────────────────────────────────────────
# Svaki bot koristi samo svoj UChat API key. Nema globalnog UCHAT_API_KEY fallback-a.
UCHAT_ESMA_API_KEY=your_esma_uchat_api_key
UCHAT_SARA_API_KEY=your_sara_uchat_api_key

# Message cluster debounce (ms). Default: 30–90 min silence before one Grok reply.
# For local testing use e.g. DEBOUNCE_MIN_MS=3000 DEBOUNCE_MAX_MS=8000
# DEBOUNCE_MIN_MS=1800000
# DEBOUNCE_MAX_MS=5400000

# ── UChat history bootstrap (one-shot import on first webhook for a subscriber) ─
# When ON (default), the first incoming message for a brand new (bot, user_ns) pair
# triggers a single GET /subscriber/chat-messages call to UChat using that bot's
# UCHAT_*_API_KEY. Up to UCHAT_HISTORY_IMPORT_LIMIT prior text messages (incoming
# + bot/agent outgoing) are inserted into Redis so Grok continues the conversation
# instead of starting from scratch. Failures are non-blocking.
# UCHAT_HISTORY_IMPORT_ENABLED=true
# UCHAT_HISTORY_IMPORT_LIMIT=15
# UCHAT_HISTORY_TIMEOUT_MS=12000

# Optional: require ?token=... on debug/admin endpoints when exposing a public tunnel.
# When set, this token also protects: /admin, /bots, /conversations, /pending,
# /failed, /messages, /triggers, and POST /clear-pending/:bot/:subscriberId.
# Pass via ?token=... query string or X-View-Token header.
# VIEW_MESSAGES_TOKEN=your-random-secret
